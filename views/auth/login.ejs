<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-8">
      <section class="panel card p-4 p-md-5">
        <div class="mb-4">
          <p class="eyebrow mb-2">Welcome back</p>
          <h1 class="h3 mb-2">Login</h1>
          <p class="text-secondary mb-0">Sign in to manage the inventory.</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/login" method="POST" class="needs-validation" novalidate>
          <div class="mb-3">
            <label class="form-label" for="name">Name</label>
            <input class="form-control" type="text" id="name" name="name" required value="<%= formData.name || '' %>" />
            <div class="invalid-feedback">Name is required.</div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="password">Password</label>
            <input class="form-control" type="password" id="password" name="password" required minlength="6" />
            <div class="invalid-feedback">Password is required.</div>
          </div>

          <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>

        <p class="mt-3 mb-0 text-center text-secondary">
          Need an account? <a href="/register">Register here</a>.
        </p>
      </section>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
