<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <section class="panel card p-4 p-md-5 text-center">
        <p class="eyebrow mb-2">Confirm delete</p>
        <h1 class="h3 mb-3"><%= gun.gunName %></h1>
        <p class="text-secondary mb-4">This page exists only as a confirmation step. Use the button below to remove the entry.</p>
        <form action="/guns/<%= gun._id %>/delete" method="POST" onsubmit="return confirm('Delete this gun?');">
          <button type="submit" class="btn btn-danger">Delete permanently</button>
          <a href="/guns/<%= gun._id %>" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
      </section>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
