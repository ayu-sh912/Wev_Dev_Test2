<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <section class="hero panel mb-4">
    <div class="row align-items-center g-4">
      <div class="col-lg-8">
        <p class="eyebrow mb-2">Inventory dashboard</p>
        <h1 class="display-6 fw-bold mb-3">Gun collection</h1>
        <p class="lead text-secondary mb-0">Create, review, update, and remove gun entries with immutable names and editable price or automatic status.</p>
      </div>
      <div class="col-lg-4 text-lg-end">
        <a href="/guns/new" class="btn btn-accent btn-lg">Add Gun</a>
      </div>
    </div>
  </section>

  <% if (!guns.length) { %>
    <div class="panel card p-5 text-center">
      <h2 class="h4">No guns added yet.</h2>
      <p class="text-secondary mb-4">Use the button above to create the first record.</p>
      <a href="/guns/new" class="btn btn-primary">Create Gun</a>
    </div>
  <% } else { %>
    <div class="table-responsive panel card">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Gun Name</th>
            <th>Price</th>
            <th>Automatic</th>
            <th>Created</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% guns.forEach((gun) => { %>
            <tr>
              <td class="fw-semibold"><%= gun.gunName %></td>
              <td>$<%= Number(gun.price).toFixed(2) %></td>
              <td>
                <span class="badge <%= gun.automatic ? 'text-bg-success' : 'text-bg-secondary' %>"><%= gun.automatic ? 'Yes' : 'No' %></span>
              </td>
              <td><%= gun.createdAt.toLocaleDateString() %></td>
              <td class="text-end">
                <div class="btn-group" role="group" aria-label="Gun actions">
                  <a href="/guns/<%= gun._id %>" class="btn btn-outline-primary btn-sm">View</a>
                  <a href="/guns/<%= gun._id %>/edit" class="btn btn-outline-warning btn-sm">Edit</a>
                  <form action="/guns/<%= gun._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this gun?');">
                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
