<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar') %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <section class="panel card p-4 p-md-5">
        <div class="mb-4">
          <p class="eyebrow mb-2">Inventory entry</p>
          <h1 class="h3 mb-2">Add Gun</h1>
          <p class="text-secondary mb-0">Gun name is required and will stay fixed after creation.</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/guns" method="POST" class="needs-validation" novalidate>
          <div class="mb-3">
            <label class="form-label" for="gunName">Gun Name</label>
            <input class="form-control" type="text" id="gunName" name="gunName" required value="<%= gun.gunName || '' %>" />
            <div class="invalid-feedback">Gun name is required.</div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="price">Price</label>
            <input class="form-control" type="number" id="price" name="price" min="0" step="0.01" required value="<%= gun.price || '' %>" />
            <div class="invalid-feedback">Price is required.</div>
          </div>

          <div class="mb-3 form-check">
            <input class="form-check-input" type="checkbox" id="automatic" name="automatic" <%= gun.automatic ? 'checked' : '' %> />
            <label class="form-check-label" for="automatic">Automatic</label>
          </div>

          <button type="submit" class="btn btn-primary">Create Gun</button>
          <a href="/guns" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
      </section>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
